POSTGRES_PASSWORD=document_search_local_password
DATABASE_URL=postgresql://postgres:document_search_local_password@127.0.0.1:5432/document_search

# Choose embedding provider: local or provider.
EMBEDDING_PROVIDER=local
CHAT_PROVIDER=provider

# Local embedding mode without an HTTP embedding service.
# Engines: sentence-transformers or flagembedding.
LOCAL_EMBED_ENGINE=sentence-transformers
LOCAL_EMBED_MODEL=/opt/models/bge-m3
LOCAL_EMBED_INDEX_ID=BAAI/bge-m3:v1
LOCAL_EMBED_DEVICE=cpu
LOCAL_EMBED_BATCH_SIZE=16
LOCAL_EMBED_NORMALIZE=true
LOCAL_EMBED_USE_FP16=false
LOCAL_EMBED_MAX_CONCURRENCY=1

# Provider-compatible API, usually something like https://host/v1.
PROVIDER_API_BASE_URL=https://provider-host/v1
PROVIDER_API_KEY=replace_me
PROVIDER_EMBED_MODEL=replace_me_if_provider_has_embeddings
PROVIDER_EMBED_INDEX_ID=replace_me_with_a_stable_model_revision
PROVIDER_CHAT_MODEL=chat-model-name
ALLOW_INSECURE_PROVIDER_HTTP=false

# OpenAI-compatible wrapper for Open WebUI.
OPENAI_COMPAT_MODEL_ID=document-search-rag
OPENAI_COMPAT_API_KEY=replace_with_a_strong_shared_secret
# Optional dedicated key; when empty, /process uses OPENAI_COMPAT_API_KEY.
OPENWEBUI_DOCUMENT_LOADER_API_KEY=
OPENWEBUI_DOCUMENT_MAX_BYTES=67108864
OPENWEBUI_CONTEXT_MAX_CHARS=60000
OPENAI_COMPAT_HOST=0.0.0.0
OPENAI_COMPAT_PORT=8000
RAG_RETRIEVAL_LIMIT=6
RAG_DOCUMENT_RESULT_LIMIT=12
RAG_DOCUMENT_MIN_VECTOR_SCORE=0.45
RAG_DOCUMENT_MIN_TEXT_SCORE=0.01
RAG_DOCUMENT_MIN_SCORE=0.05
RAG_DOCUMENT_RELATIVE_CUTOFF=0.55
RAG_DOCUMENT_MIN_COMPETITIVE_SIGNAL=0.25
RAG_EMBEDDING_DIM=1024
RAG_CHAT_HISTORY_LIMIT=24
RAG_DOCUMENT_ROOTS=/home/pozdniakov/rag_template/docs:/home/pozdniakov/openwebuig/docs
RAG_FORCE_EXTRACTIVE=false
