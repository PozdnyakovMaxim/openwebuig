ENABLE_LDAP=True
LDAP_SERVER_LABEL=Corporate AD
LDAP_SERVER_HOST=dc01.example.local
LDAP_SERVER_PORT=636
LDAP_USE_TLS=True
LDAP_VALIDATE_CERT=True
LDAP_CA_CERT_FILE=/app/backend/data/certs/company-ca.crt

LDAP_APP_DN=CN=svc_glavstroy_llm,OU=Service Accounts,DC=example,DC=local
LDAP_APP_PASSWORD=replace_me

LDAP_SEARCH_BASE=OU=Users,DC=example,DC=local
LDAP_SEARCH_FILTER=(memberOf=CN=GlavstroyLLM Users,OU=Groups,DC=example,DC=local)

LDAP_ATTRIBUTE_FOR_USERNAME=sAMAccountName
LDAP_ATTRIBUTE_FOR_MAIL=mail
LDAP_ATTRIBUTE_FOR_NAME=displayName
